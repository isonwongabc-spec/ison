# OKX Trading Configuration Template
# Copy this file to okx-trading.env and fill in your real API credentials

API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=your_passphrase_here

# Trading Settings
INITIAL_CAPITAL=70
MAX_LEVERAGE=3
STOP_LOSS_PERCENT=2
TAKE_PROFIT_PERCENT=6
DAILY_MAX_LOSS_PERCENT=5

# Risk Management
MAX_POSITION_SIZE_USD=20
MAX_CONCURRENT_POSITIONS=2
ENABLE_TRAILING_STOP=true
ENABLE_BREAKER=true

# Symbols to Trade
TRADE_ETH=true
TRADE_BTC=true

# Timeframes
SIGNAL_TIMEFRAME=4h
CHECK_INTERVAL_MINUTES=5

# Notifications
NOTIFY_ON_ENTRY=true
NOTIFY_ON_EXIT=true
NOTIFY_DAILY_SUMMARY=true
